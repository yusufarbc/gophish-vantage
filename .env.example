# ── Domain Configuration ─────────────────────────────────────────────────────
DOMAIN=gophish.example.com

# ── Caddyfile Auth (generate with: caddy hash-password) ────────────────────
# Example password hash (password: "admin123"):
VANTAGE_PASSWORD_HASH=$2a$14$R9h/cIPz0gi.URNNX3kh2OPST9/PgBkqquzi.Ee3D6xVxQo0kK7dm

# ── Postfix Configuration ─────────────────────────────────────────────────────
# SMTP relay host for outbound mail (optional)
# POSTFIX_RELAYHOST=[smtp.gmail.com]:587
# POSTFIX_RELAYHOST_USERNAME=your-email@gmail.com
# POSTFIX_RELAYHOST_PASSWORD=your-app-password

# ── Tailscale VPN (Optional) ──────────────────────────────────────────────────
# Generate at: https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTH_KEY=tskey-xxxxxxxxxxxxxxxxxxxxxx

# ── Gophish Configuration ─────────────────────────────────────────────────────
GOPHISH_ADMIN_PORT=3333
GOPHISH_PHISH_PORT=80

# ── Reverse L3 Tunneling (Chisel) ───────────────────────────────────────────
# Secret for Chisel server/agent authentication (optional but recommended)
# VANTAGE_TUNNEL_SECRET=your-secret-key-here
# Chisel listener port (internal/external)
# VANTAGE_TUNNEL_PORT=9090

