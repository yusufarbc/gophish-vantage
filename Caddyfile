# ═════════════════════════════════════════════════════════════════════════════
# Caddy Reverse Proxy Configuration for Vantage
# Handles: TLS termination, Basic Auth, WebSocket, Rate limiting, Security headers
# ═════════════════════════════════════════════════════════════════════════════

{
    # Global configuration
    email admin@vantage.local
    admin 0.0.0.0:2019
    
    # Log configuration
    log {
        level info
        format json
    }

    # Auto-HTTPS settings
    auto_https on
    default_sni localhost
}

# ═════════════════════════════════════════════════════════════════════════════
# Security Middleware Snippet
# ═════════════════════════════════════════════════════════════════════════════

(security_headers) {
    # Prevent clickjacking
    header X-Frame-Options "DENY"
    
    # Prevent MIME sniffing
    header X-Content-Type-Options "nosniff"
    
    # XSS protection
    header X-XSS-Protection "1; mode=block"
    
    # Referrer policy
    header Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (permissive for Vantage)
    header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' ws: wss:;"
    
    # HSTS (preload optional, requires domain registration)
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    # Permissions Policy (formerly Feature Policy)
    header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
}

(basic_auth) {
    # Basic authentication
    # Generate password hash: caddy hash-password -plaintext "password"
    basicauth /* {
        # admin JDJhJDEwJFZWWTFFUnhCWGQ3TUl0RWxkblMzT21DT0ljRDkuWmZGSWJnRUFha05LMUJBdW1CMnVRb2N1
    }
}

# ═════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT: Local HTTP Server (No TLS, No Auth)
# ═════════════════════════════════════════════════════════════════════════════

:8080 {
    import security_headers
    
    # Main reverse proxy handler
    reverse_proxy vantage-core:3333 {
        # Preserve original request information
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        
        # WebSocket support (must be after headers)
        websocket
    }
    
    # Compression
    encode gzip
    
    # Logging
    log {
        output file /var/log/caddy/vantage-dev.log {
            roll_size 10mb
            roll_keep 3
        }
        format json
    }
}

# ═════════════════════════════════════════════════════════════════════════════
# PRODUCTION: HTTPS with TLS and Basic Auth
# Replace {$DOMAIN} with actual domain (e.g., vantage.example.com)
