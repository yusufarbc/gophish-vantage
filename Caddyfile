# ═════════════════════════════════════════════════════════════════════════════
# API Endpoint with Rate Limiting
# ═════════════════════════════════════════════════════════════════════════════

# api.{$DOMAIN:localhost}:8443 {
#     import security_headers
#     # import basic_auth
#     
#     tls self_signed
#     
#     # Rate limiting middleware
#     @api path /api/*
#     
#     route @api {
#         rate_limit 100 1m {
#             zone static/ip {remote_host}
#         }
#         
#         reverse_proxy vantage-core:3333 {
#             header_up X-Forwarded-For {remote_host}
#             header_up X-Forwarded-Proto https
#             
#             # Timeouts
#             transport http {
#                 dial_timeout 30s
#                 response_header_timeout 60s
#                 expect_continue_timeout 2s
#             }
#         }
#     }
#     
#     log {
#         output file /var/log/caddy/api-access.log
#         format json
#     }
# }

# ═════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT INSTRUCTIONS
# ═════════════════════════════════════════════════════════════════════════════

# 1. For Development (HTTP):
#    - Keep the ":8080" block active (currently active)
#    - Access: http://localhost:8080
#    - In docker-compose.yml: ports: ["8080:8080"]
#
# 2. For Production (HTTPS):
#    - Edit this file, replace {$DOMAIN} with your domain (e.g., vantage.example.com)
#    - Uncomment the production blocks
#    - Generate password hash: 
#      docker run caddy caddy hash-password -plaintext "your_secure_password"
#    - Set environment variable: DOMAIN=vantage.example.com
#    - Ensure DNS records point to your server
#    - Let's Encrypt will auto-provision certificates
#
# 3. Generate Basic Auth Hash:
#    docker run --rm -it caddy:latest caddy hash-password -plaintext "mypassword"
#
# 4. View Caddy Logs:
#    docker-compose logs -f caddy
#
# 5. Reload Configuration Without Restart:
#    docker-compose exec caddy caddy reload -c /etc/caddy/Caddyfile
#
# 6. Test Configuration:
#    caddy validate --config /etc/caddy/Caddyfile

